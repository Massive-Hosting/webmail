{
  "$schema": "https://raw.githubusercontent.com/nicbarker/tauri/v2/crates/tauri-cli/schema.json",
  "productName": "Webmail",
  "version": "0.1.0",
  "identifier": "com.webmail.desktop",
  "build": {
    "frontendDist": "http://localhost:8095",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["binaries/*"]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/nicbarker/webmail/releases/latest/download/latest.json"
      ],
      "pubkey": "",
      "dialog": true
    }
  }
}
