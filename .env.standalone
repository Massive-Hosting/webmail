# Webmail Standalone Configuration
# Copy this file and edit the values below.

# === REQUIRED ===

# Your Stalwart Mail Server JMAP URL
STALWART_URL=http://localhost:8081

# Stalwart admin token (found in Stalwart's config under "authentication.fallback-admin.secret")
STALWART_ADMIN_TOKEN=your-admin-token-here

# Encryption key for session data. Generate once and keep stable:
#   openssl rand -hex 32
SECRET_ENCRYPTION_KEY=change-me-generate-with-openssl-rand-hex-32

# Database (uses the postgres container from docker-compose.yml)
WEBMAIL_DATABASE_URL=postgres://webmail:webmail@postgres:5432/webmail?sslmode=disable

# Session store (uses the valkey container from docker-compose.yml)
VALKEY_URL=redis://valkey:6379/0

# === OPTIONAL ===

# AI assistant (any OpenAI-compatible API: OpenAI, Anthropic, Gemini, Ollama, etc.)
# AI_ENABLED=true
# AI_BASE_URL=https://api.openai.com
# AI_API_KEY=sk-...
# AI_MODEL=gpt-4o

# Snooze & scheduled send (requires Temporal — uncomment in docker-compose.yml)
# TEMPORAL_ADDRESS=temporal:7233

# TURN relay for Wave video calls behind NAT (requires coturn)
# TURN_SECRET=your-shared-secret
# TURN_SERVERS=turn:your-server.com:3478

# CORS (set to your webmail's public URL if behind a reverse proxy)
# WEBMAIL_ALLOWED_ORIGINS=https://mail.example.com
